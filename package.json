{
    "name": "@iobroker/adapter-core",
    "version": "3.3.2",
    "description": "Core module to be used in ioBroker adapters. Acts as the bridge to js-controller.",
    "engines": {
        "node": ">=18"
    },
    "author": {
        "name": "AlCalzone",
        "email": "d.griesel@gmx.net"
    },
    "imports": {
        "#require": {
            "types": "./src/require/require.d.ts",
            "esbuild": "./src/require/require.cjs",
            "import": "./src/require/require.mjs",
            "require": "./src/require/require.cjs"
        }
    },
    "main": "build/cjs/index.js",
    "types": "build/esm/index.d.ts",
    "module": "build/esm/index.js",
    "exports": {
        ".": {
            "import": {
                "types": "./build/esm/index.d.ts",
                "default": "./build/esm/index.js"
            },
            "require": {
                "types": "./build/cjs/index.d.ts",
                "default": "./build/cjs/index.js"
            }
        },
        "./credentials": {
            "import": {
                "types": "./build/esm/credentials.d.ts",
                "default": "./build/esm/credentials.js"
            },
            "require": {
                "types": "./build/cjs/credentials.d.ts",
                "default": "./build/cjs/credentials.js"
            }
        }
    },
    "scripts": {
        "prebuild": "rimraf ./build",
        "build": "tsc -p src/tsconfig.json",
        "postbuild": "esm2cjs --in ./build/esm --out ./build/cjs -l error && cpy ./**/*.d.ts ../cjs/ --cwd=build/esm/ && node postbuild.mjs",
        "watch": "tsc -p src/tsconfig.json --watch",
        "lint:ts": "eslint -c eslint.config.mjs src",
        "lint": "npm run lint:ts",
        "test:declarations": "tsc -p test/types/tsconfig.json",
        "test:ts": "node test/run-ts-tests.js",
        "test:i18n": "mocha test/testI18n.js",
        "test": "npm run test:declarations && npm run test:i18n",
        "prepublishOnly": "npm run lint && npm run build",
        "release": "release-script -y --noPush"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ioBroker/adapter-core.git"
    },
    "keywords": [
        "iobroker",
        "adapter",
        "iot"
    ],
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/ioBroker/adapter-core/issues"
    },
    "files": [
        "build",
        "LICENSE"
    ],
    "homepage": "https://github.com/ioBroker/adapter-core#readme",
    "devDependencies": {
        "@alcalzone/esm2cjs": "^1.4.2",
        "@alcalzone/release-script": "^5.2.1",
        "@alcalzone/release-script-plugin-license": "^5.2.0",
        "@iobroker/eslint-config": "^2.3.4",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.19.20",
        "@types/proxyquire": "^1.3.31",
        "@types/sinon": "^21.0.1",
        "cpy-cli": "^6.0.0",
        "mocha": "^11.7.6",
        "prettier": "^3.8.3",
        "proxyquire": "^2.1.3",
        "rimraf": "^6.1.3",
        "sinon": "^22.0.0",
        "source-map-support": "^0.5.21",
        "ts-node": "^10.9.2",
        "typescript": "~6.0.3"
    },
    "peerDependencies": {
        "@iobroker/types": ">=6.0.11"
    }
}
