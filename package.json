{
  "name": "@iobroker/adapter-core",
  "version": "3.4.3",
  "description": "Core module to be used in ioBroker adapters. Acts as the bridge to js-controller.",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "AlCalzone",
    "email": "d.griesel@gmx.net"
  },
  "main": "build/cjs/index.js",
  "types": "build/esm/index.d.ts",
  "module": "build/esm/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./build/esm/index.d.ts",
        "default": "./build/esm/index.js"
      },
      "require": {
        "types": "./build/cjs/index.d.ts",
        "default": "./build/cjs/index.js"
      }
    },
    "./credentials": {
      "import": {
        "types": "./build/esm/credentials.d.ts",
        "default": "./build/esm/credentials.js"
      },
      "require": {
        "types": "./build/cjs/credentials.d.ts",
        "default": "./build/cjs/credentials.js"
      }
    },
    "./tools": {
      "import": {
        "types": "./build/esm/tools.d.ts",
        "default": "./build/esm/tools.js"
      },
      "require": {
        "types": "./build/cjs/tools.d.ts",
        "default": "./build/cjs/tools.js"
      }
    },
    "./exitCodes": {
      "import": {
        "types": "./build/esm/exitCodes.d.ts",
        "default": "./build/esm/exitCodes.js"
      },
      "require": {
        "types": "./build/cjs/exitCodes.d.ts",
        "default": "./build/cjs/exitCodes.js"
      }
    },
    "./i18n": {
      "import": {
        "types": "./build/esm/i18n.d.ts",
        "default": "./build/esm/i18n.js"
      },
      "require": {
        "types": "./build/cjs/i18n.d.ts",
        "default": "./build/cjs/i18n.js"
      }
    },
    "./TokenRefresher": {
      "import": {
        "types": "./build/esm/TokenRefresher.d.ts",
        "default": "./build/esm/TokenRefresher.js"
      },
      "require": {
        "types": "./build/cjs/TokenRefresher.d.ts",
        "default": "./build/cjs/TokenRefresher.js"
      }
    }
  },
  "scripts": {
    "prebuild": "rimraf ./build",
    "build": "tsc -p src/tsconfig.json",
    "postbuild": "esm2cjs --in ./build/esm --out ./build/cjs -l error && cpy ./**/*.d.ts ../cjs/ --cwd=build/esm/",
    "watch": "tsc -p src/tsconfig.json --watch",
    "lint:ts": "eslint -c eslint.config.mjs src",
    "lint": "npm run lint:ts",
    "test:declarations": "tsc -p test/types/tsconfig.json",
    "test:ts": "node test/run-ts-tests.js",
    "test:i18n": "mocha test/testI18n.js",
    "test": "npm run test:declarations && npm run test:i18n",
    "prepublishOnly": "npm run lint && npm run build",
    "release": "release-script -y --noPush"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ioBroker/adapter-core.git"
  },
  "keywords": [
    "iobroker",
    "adapter",
    "iot"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ioBroker/adapter-core/issues"
  },
  "files": [
    "build",
    "LICENSE"
  ],
  "homepage": "https://github.com/ioBroker/adapter-core#readme",
  "devDependencies": {
    "@alcalzone/esm2cjs": "^1.4.2",
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/js-controller-common": "^7.2.2",
    "@iobroker/js-controller-common-db": "^7.2.2",
    "@iobroker/types": "^7.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^21.0.1",
    "cpy-cli": "^6.0.0",
    "mocha": "^11.7.6",
    "prettier": "^3.9.5",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.1.3",
    "sinon": "^22.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "@iobroker/types": ">=6.0.11",
    "@iobroker/js-controller-common-db": ">=7.2.2"
  }
}
